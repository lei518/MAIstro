# Browser mode is easiest for laptop development. Hardware mode is for Raspberry Pi I2S mic.
MAISTRO_AUDIO_SOURCE=browser
MAISTRO_AUDIO_SAMPLE_RATE=48000
MAISTRO_PITCH_SAMPLE_RATE=16000
MAISTRO_PITCH_TOLERANCE_CENTS=50
MAISTRO_PITCH_CONFIDENCE_MIN=0.30

# CREPE TFLite model path. Copy your model to backend/models/crepe.tflite.
MAISTRO_CREPE_TFLITE=/app/backend/models/crepe.tflite

# Audiveris option A: run Audiveris directly in the backend container/host.
AUDIVERIS_CMD=Audiveris
AUDIVERIS_TIMEOUT_SECONDS=180

# Audiveris option B: call laptop OMR service instead, e.g. http://192.168.1.20:8100/convert-sheet
OMR_SERVICE_URL=

# CORS
MAISTRO_CORS_ALLOW_ORIGINS=*
